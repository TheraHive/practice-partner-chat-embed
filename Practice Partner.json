    {
      "parameters": {
        "jsCode": "const action = $('Chat Interface').first().json.action;\nconst chatInput = $('Chat Interface').first().json.chatInput;\n\nif (action === 'loadPreviousSession' || !chatInput || chatInput.trim() === '') {\n  return [];\n}\n\nconst character = $('Chat Interface').first().json.metadata?.character || 'nikki';\nconst systemMessage = $('Fetch Partner Prompt').first().json.data || '';\n\nreturn [{ json: {\n  systemMessage: systemMessage,\n  character: character,\n  chatInput: chatInput\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        304
      ],
      "id": "bc45526e-649e-4c34-a42f-fb8f6d84a5dd",
      "name": "Load System Prompt"
    },
    {
      "parameters": {
        "jsCode": "const exitMessage = $('Strip Exit Tag').first().json.output;\nconst feedback = $('Generate Feedback').first().json.text;\n\nconst combined = exitMessage + '\\n\\n---\\n\\n**A note from your coach:** ' + feedback;\n\nreturn [{ json: { output: combined } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        80
      ],
      "id": "082c43a3-0a06-431e-b5c0-536b3e8b566a",
      "name": "Combine Messages"
    },
    {
      "parameters": {
        "jsCode": "const sessionStatus = $('Strip Exit Tag').first().json.sessionStatus;\nconst exitMessage = $('Strip Exit Tag').first().json.output;\nconst characterPrompt = $('Load System Prompt').first().json.systemMessage || '';\n\n// Extract just the skill section — drop personality, voice, backstory\nconst skillMatch = characterPrompt.match(/## THE SKILL YOU ARE PRACTICING[\\s\\S]*/);\nconst skillContext = skillMatch ? skillMatch[0].trim() : characterPrompt;\n\nconst messages = $('Fetch Conversation').all();\nconst conversationText = messages\n  .map(m => `${m.json.role === 'user' ? 'Human' : 'AI'}: ${m.json.content}`)\n  .join('\\n');\n\nlet feedbackPrompt;\nif (sessionStatus === 'case1') {\n  feedbackPrompt = `You are a TheraHive DBT skills coach reviewing a practice session. A student was guiding a practice partner through a DBT skill exercise, but the session ended early because their guidance went off track.\n\nHere is the skill context for this session:\n${skillContext}\n\nHere is the conversation:\n${conversationText}\n\nWrite a short, warm coaching note (2-3 sentences) to the student. Acknowledge their effort, briefly explain what specifically went off track based on the conversation and the skill steps, and give one concrete suggestion for next time. Conversational, no bullet points, no headers. Start with \"A note from your TheraHive Coach:\"`;\n} else {\n  feedbackPrompt = `You are a TheraHive DBT skills coach reviewing a practice session. A student successfully guided a practice partner through a complete DBT skill exercise.\n\nHere is the skill context for this session:\n${skillContext}\n\nHere is the conversation:\n${conversationText}\n\nWrite a short, warm coaching note (2-3 sentences) celebrating their success. Reference one specific thing they did well based on the actual conversation. Encourage continued practice. Conversational, no bullet points, no headers. Start with \"A note from your TheraHive Coach:\"`;\n}\n\nreturn [{ json: { feedbackPrompt, exitMessage, sessionStatus } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
