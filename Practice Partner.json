    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json.output;\nconst case1 = agentOutput.includes('[SESSION_END_CASE1]');\nconst case2 = agentOutput.includes('[SESSION_END_CASE2]');\n\nlet cleanMessage = agentOutput\n  .replace('[SESSION_END_CASE1]', '')\n  .replace('[SESSION_END_CASE2]', '')\n  .trim();\n\n// Normalize any markdown link where LLM wrapped URL in angle brackets\n// e.g. [text](<https://...>) → [text](https://...)\ncleanMessage = cleanMessage\n  .replace(/\\[([^\\]]+)\\]\\(<([^>]+)>\\)/g, '[$1]($2)');\n\nconst sessionStatus = case1 ? 'case1' : case2 ? 'case2' : '';\nconst isExit = case1 || case2;\n\nreturn [{ json: { output: cleanMessage, sessionStatus, isExit } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        304
      ],
      "id": "45d37127-ae90-4296-8cf2-4e2493fccd43",
